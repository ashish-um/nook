  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dotenv": "^17.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
