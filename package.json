{
  "name": "drive-crud",
  "version": "1.0.0",
  "description": "A reusable TypeScript module for using Google Drive as per-user cloud storage",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest"
  },
  "keywords": [],
